---

import Navbar from "@/components/header/Navbar.astro";
import "../styles/global.css";
import Footer from "@/components/footer/Footer.astro";
import menuWeb from '@/assets/logos/logo.webp'

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description = 'Centro de investigacion de Nordvital IPS', canonical }: Props = Astro.props;
const siteUrl = 'https://investigation.nordvitalips.com';
const pageUrl = canonical ? `${siteUrl}${canonical}` : siteUrl + Astro.url.pathname;

---

<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/svg+xml" href={menuWeb.src}>
  <meta name="generator" content={Astro.generator} />
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow, max-snippet:150, max-image-preview:large" />
  <link rel="canonical" href={pageUrl} />
  <link rel="alternate" hreflang="es" href={`${siteUrl}${Astro.url.pathname}`} />
  <link rel="alternate" hreflang="en" href={`${siteUrl}/en${Astro.url.pathname}`} />
  <link rel="alternate" hreflang="x-default" href={pageUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={pageUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://investigation.nordvitalips.com/og-image.jpg" />
  <meta name="twitter:card" content="summary_large_image" />
  <title>{title}</title>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Nordvital IPS - Centro de Investigación",
    "url": "https://investigation.nordvitalips.com",
    "description": "Centro de investigación en Cúcuta, Colombia.",
    "email": "institutodeinvestigacion@nordvitalips.com",
    "telephone": "+573242800091",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "AV 3A E #13A - 82 CAOBOS",
      "addressLocality": "Cúcuta",
      "addressRegion": "Norte de Santander",
      "addressCountry": "CO"
    },
    "areaServed": {
      "@type": "Country",
      "name": "Colombia"
    },
    "serviceType": "Investigación clínica",
    "priceRange": "$$"
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Nordvital IPS - Centro de Investigación",
    "url": "https://investigation.nordvitalips.com",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://investigation.nordvitalips.com/{search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
  </script>
  <script is:inline>
    (function () {
      var lang = localStorage.getItem('lang');
      if (lang && lang !== 'es') {
        document.documentElement.style.visibility = 'hidden';
      }
    })();
  </script>
</head>
  <body>
    <Navbar/>
    <main>
      <slot />
    </main>
    <Footer/>
  </body>
</html>


<style>
    html, body {
        margin: 0;
        padding: 0;
        width: 100%;
        min-height: 100vh;
    }
</style>

<script>
  import { initI18n } from "@/scripts/i18n.ts";
  initI18n();
</script>