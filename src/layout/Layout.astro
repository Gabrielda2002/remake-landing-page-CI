---

import Navbar from "@/components/header/Navbar.astro";
import "../styles/global.css";
import Footer from "@/components/footer/Footer.astro";
import {Form} from "@/components/react/Form"
import Research from "@/components/research/Research.astro";
import Professional from "@/components/professional/Professional.astro";
import Institute from "@/components/institute/Institute.astro";
import TextContent from "@/components/text/TextContent.astro";
import AboutUs from "@/components/about-us/AboutUs.astro";
import LandingHero from "@/components/landingHero/LandingHero.astro";

interface Props {
  title: string;
    description: string;
}

const  { title, description = 'Centreo de investigacion de Nordvital IPS' }: Props = Astro.props;

---

<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/svg+xml" href="/content/logos/logo.webp" />
  <meta name="generator" content={Astro.generator} />
  <meta name="description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://investigation.nordvitalips.com" />
  <title>{title}</title>
  <title>Document</title>
  <script is:inline>
    (function () {
      var lang = localStorage.getItem('lang');
      if (lang && lang !== 'es') {
        document.documentElement.style.visibility = 'hidden';
      }
    })();
  </script>
</head>
  <body>
    <main>
      <section id="inicio" class="hero-wrapper">
        <LandingHero/>
        <div class="hero-navbar">
          <Navbar/>
        </div>
      </section>
      <section id="quieneSomos">
        <AboutUs />
      </section>
      <section id="trayectoria">
        <TextContent />
      </section>
      <section id="instituto">
        <Institute />
      </section>
      <Professional/>
      <section id="servicios">
        <Research/>
      </section>
      <section id="contactenos">
        <Form  client:load/>
      </section>
      <slot />
    </main>
    <Footer/>
  </body>
</html>


<style>
    html, body {
        margin: 0;
        padding: 0;
        width: 100%;
        min-height: 100vh;
    }

  .hero-wrapper {
    position: relative;
    width: 100%;
  }

  .hero-navbar {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 10;
  }
</style>

<script>
  import { initI18n } from "@/scripts/i18n.ts";
  initI18n();
</script>