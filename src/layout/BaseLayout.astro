---
import Navbar from "@/components/header/Navbar.astro";
import Footer from "@/components/footer/Footer.astro";
import "../styles/global.css";
import menuWeb from '@/assets/logos/logo.webp';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Centro de investigación de Nordvital IPS' } = Astro.props;
---

<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/svg+xml" href={menuWeb.src}>
  <meta name="description" content={description} />
  <title>{title}</title>
</head>
<body>
  <Navbar />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>

<style>
  html, body {
    margin: 0;
    padding: 0;
    width: 100%;
    min-height: 100vh;
  }
</style>

<script>
  import { initI18n } from "@/scripts/i18n.ts";
  initI18n();
</script>