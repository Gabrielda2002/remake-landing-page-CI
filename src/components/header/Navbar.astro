---
import Menu from './Menu.astro';
import SocialIcons from './SocialIcons.astro';
import LanguageSelector from './LanguageSelector.astro';
import LogoWeb from '@logo/logo.webp'
import menuWb from '@/assets/menu/menu.webp';
import Logo from '../ui/Logo.astro';
import '@styles/navbar.css';
---

<header class="navbar-header font-['Bai_Jamjuree',sans-serif]">
  <div class="header-actions flex items-center justify-between rounded-4xl p-3 bg-[rgb(255,255,255)] shadow-[0_4px_20px_rgba(0,0,0,0.2)]">
    <details class="nav-mobile-menu">
      <summary aria-label="Abrir menú" title="Abrir menú">
        <img src={menuWb.src} alt="Abrir menú" class="w-10 h-10 object-contain" />
      </summary>
      <div class="nav-mobile-dropdown">
        <Menu />
      </div>
    </details>

    <div class="brand-container w-[30%] md:w-[25%] ml-5">
      <div class="brand-desktop-logo">
        <Logo />
      </div>
      <img src={LogoWeb.src} alt="Nordvital" class="brand-mobile-logo" />
    </div>

    <div class="w-[50%] flex justify-center nav-desktop-menu">
      <Menu />
    </div>

    <div class="flex items-center justify-end gap-1 w-[20%] md:w-[25%] mr-5 nav-desktop-extra">
      <SocialIcons />
      <LanguageSelector />
    </div>
  </div>
</header>

<script>
  const navbar = document.querySelector('.navbar-header');
  const mobileMenu = document.querySelector('.nav-mobile-menu') as HTMLDetailsElement | null;
  let lastScrollTop = 0;
  const SCROLL_THRESHOLD = 100;

  // Cerrar menú al hacer click fuera
  document.addEventListener('click', (e) => {
    if (mobileMenu?.open && !mobileMenu.contains(e.target as Node)) {
      mobileMenu.open = false;
    }
  });

  // Controlar navbar con scroll
  window.addEventListener('scroll', () => {
    const currentScroll = window.scrollY;
    const isScrollingDown = currentScroll > lastScrollTop;
    const isNearTop = currentScroll < SCROLL_THRESHOLD;

    if (isNearTop) {
      navbar?.classList.remove('navbar-hidden');
    } else if (isScrollingDown) {
      navbar?.classList.add('navbar-hidden');
      if (mobileMenu) mobileMenu.open = false;
    } else {
      navbar?.classList.remove('navbar-hidden');
    }

    lastScrollTop = Math.max(0, currentScroll);
  });
</script>
