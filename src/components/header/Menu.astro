---
export interface MenuItem {
  href: string;
  label: string;
  i18nKey?: string
}

interface Props {
  items?: MenuItem[];
}

const defaultItems: Array<MenuItem> = [
  { href: "#inicio", label: "Inicio", i18nKey: "nav.inicio" },
  { href: "#quienes-somos",label: "Quienes Somos", i18nKey: "nav.quienesSomos" },
  { href: "#trayectoria", label: "Trayectoria", i18nKey: "nav.trayectoria" },
  { href: "#instituto", label: "Instituto de Investigación", i18nKey: "nav.instituto" },
  { href: "#servicios", label: "Servicios", i18nKey: "nav.servicios" },
  { href: "#contactenos", label: "Contáctenos", i18nKey: "nav.contactenos" },
];

const { items = defaultItems } = Astro.props;
---

<div class=menu-container>
  <nav class="menu flex justify-center items-center space-x-1 lg:space-x-2 text-sm font-bold tracking-wide">
    {items.map((item) => (
      <a 
        href={item.href}
        data-section={item.href.replace('#', '')}
        data-i18n={item.i18nKey}
        class="text-[rgb(0,121,196)] hover:bg-[rgb(219,218,218)] px-1.5 py-1.5 rounded transition whitespace-nowrap menu-link"
        aria-current={item.href === "#inicio" ? "page" : undefined}
      >
        {item.label}
      </a>
    ))}
  </nav>
</div>

<script>
import { initSmoothScroll } from "@/scripts/smoothScroll";
  initSmoothScroll();
</script>