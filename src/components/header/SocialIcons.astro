---
import { socialLinks } from '../../data/socialLinks';
---

<div class="social-container flex items-center space-x-2.5">
  {socialLinks.map((link, index) => (
    <a 
      href={link.url}
      target="_blank" 
      class="social-icon transition relative group px-1 py-2 hover:bg-[rgb(219,218,218)] rounded"
      title={link.nombre}
    >
      <span set:html={link.svg} />
      <span class={`absolute top-full mt-2 px-3 py-2 bg-[rgb(0,179,160)] text-white text-[16px] rounded-2xl opacity-0 group-hover:opacity-100 transition text-center pointer-events-none w-40 leading-tight z-30
        ${index === socialLinks.length - 1 ? 'right-0' : 'left-1/2 -translate-x-1/2'}`}>
        {link.tooltip}
      </span>
    </a>
  ))}
</div>