---
import coFlag from "/content/banderas/flag-co.svg?url";
import gbFlag from "/content/banderas/flag-gb.svg?url";
import logoText from "/content/logos/logotexto.webp?url";
---

<div class="header-actions flex items-center justify-between rounded-4xl mt-5 mx-4 md:mx-15 p-5 bg-[rgb(255,255,255)] shadow-[0_4px_20px_rgba(0,0,0,0.2)]" style="font-family: 'Bai Jamjuree', sans-serif; font-size: 1.25rem;">  <!-- Logo - sin cambios, está bien -->
  <div class="logo-containers w-[30%] md:w-[25%] pl-2">
    <a href="/" class="logo"><img src={logoText} alt="Nordvital Logo" width="120" height="40"></a>
  </div>
  
  <!-- Menu -->
  <div class="menu-container hidden md:flex w-[50%] justify-center">
    <nav class="menu flex justify-center items-center space-x-2 lg:space-x-4 text-sm font-bold tracking-wide">
      <a href="#inicio" class="text-[rgb(0,121,196)] hover:bg-[rgb(219,218,218)] px-3 py-1.5 rounded transition whitespace-nowrap">Inicio</a>
      <a href="#quienes-somos" class="text-[rgb(0,121,196)] hover:bg-[rgb(219,218,218)] px-3 py-1.5 rounded transition whitespace-nowrap">Quienes Somos</a>
      <a href="#trayectoria" class="text-[rgb(0,121,196)] hover:bg-[rgb(219,218,218)] px-3 py-1.5 rounded transition whitespace-nowrap">Trayectoria</a>
      <a href="#instituto" class="text-[rgb(0,121,196)] hover:bg-[rgb(219,218,218)] px-3 py-1.5 rounded transition whitespace-nowrap">Instituto</a>
      <a href="#servicios" class="text-[rgb(0,121,196)] hover:bg-[rgb(219,218,218)] px-3 py-1.5 rounded transition whitespace-nowrap">Servicios</a>
      <a href="#contactenos" class="text-[rgb(0,121,196)] hover:bg-[rgb(219,218,218)] px-3 py-1.5 rounded transition whitespace-nowrap">Contáctenos</a>
    </nav>
  </div>
  <!-- logos -->
  <div class="flex items-center justify-end w-[70%] md:w-[25%] space-x-4">

    <!-- Redes -->
    <div class="social-container flex items-center space-x-2.5">
      <a 
        href="https://www.facebook.com/Nordvitaloficial/"
        target="_blank" 
        class="social-icon transition relative group px-1 py-2 hover:bg-[rgb(219,218,218)] rounded"
        title="facebook"
      >
        <svg 
          xmlns="http://www.w3.org/2000/svg" 
          width="22" 
          height="22" 
          viewBox="0 0 24 24" 
          fill="#00b3a0">
          <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.879v-6.99h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.99C18.343 21.128 22 16.991 22 12z"/>
        </svg>
        <span class="absolute top-full left-1/2 transform -translate-x-1/2 mt-2 px-3 py-2 bg-[rgb(0,179,160)] text-white text-[16px] rounded-2xl opacity-0 group-hover:opacity-100 transition text-center pointer-events-none w-40 leading-tight z-30" style="font-family: 'PrimeIcons', sans-serif; word-wrap: break-word;">
          Seleccione para ir a la página de Facebook
        </span>
      </a>

      <a 
        href="https://www.instagram.com/nordvital_ips/?hl=en" 
        target="_blank" 
        class="social-icon transition relative group px-1 py-2 hover:bg-[rgb(219,218,218)] rounded"
      >
        <svg xmlns="http://www.w3.org/2000/svg"
          width="22" 
          height="22" 
          viewBox="0 0 24 24" 
          fill="#00b3a0">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zM5.838 12a6.162 6.162 0 1 1 12.324 0 6.162 6.162 0 0 1-12.324 0zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm4.965-10.405a1.44 1.44 0 1 1 2.881.001 1.44 1.44 0 0 1-2.881-.001z"/>
        </svg>
        <span class="absolute top-full left-1/2 transform -translate-x-1/2 mt-2 px-3 py-2 bg-[rgb(0,179,160)] text-white text-[16px] rounded-2xl opacity-0 group-hover:opacity-100 transition text-center pointer-events-none w-40 leading-tight z-30" style="font-family: 'PrimeIcons', sans-serif; word-wrap: break-word;">
          Seleccione para ir a la página de Instagram
        </span>
      </a>

      <a 
        href="https://www.tiktok.com/@nordvital1"
        target="_blank" 
        class="social-icon transition relative group px-1 py-2 hover:bg-[rgb(219,218,218)] rounded"
        title="tiktok"
        >
        <svg xmlns="http://www.w3.org/2000/svg" 
          width="22" 
          height="22" 
          viewBox="0 0 24 24" 
          fill="#00b3a0">
          <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.88-3.58 3.17-5.91 3.04-1.87-.11-3.64-.98-4.87-2.4-1.34-1.56-2.01-3.68-1.79-5.72.3-2.82 2.3-5.31 5.01-6.13 1.06-.32 2.18-.4 3.26-.23.02 1.17-.02 2.35-.02 3.52-.51-.15-1.06-.21-1.6-.13-1.18.17-2.24.96-2.82 1.98-.53.94-.7 2.07-.43 3.13.34 1.3 1.4 2.4 2.71 2.74.99.26 2.08.06 2.89-.55.88-.67 1.39-1.79 1.34-2.89.07-3.18.03-6.37.03-9.55 1.49.98 3.28 1.56 5.07 1.54.01-1.52.01-3.04.02-4.56z"/>
        </svg>
        <span class="absolute top-full left-1/2 transform -translate-x-1/2 mt-2 px-3 py-2 bg-[rgb(0,179,160)] text-white text-[16px] rounded-2xl opacity-0 group-hover:opacity-100 transition text-center pointer-events-none w-40 leading-tight z-30">
          Seleccione para ir a la página de TikTok
        </span>
      </a>
    </div>
    
  <!-- Banderas -->
  <div class="language-group relative" id="languageSelector">
    <div class="selected-wrapper flex items-center px-1 py-2 transition hover:bg-[rgb(219,218,218)] rounded cursor-pointer relative group" id="selectedWrapper">
      <img src={coFlag} alt="Español" width="24" height="16" class="rounded-sm" id="currentFlag">
      
      <span class="absolute top-full left-1/2 transform -translate-x-1/2 mt-2 px-3 py-2 bg-[rgb(0,179,160)] text-white text-[16px] rounded-2xl opacity-0 group-hover:opacity-100 transition text-center pointer-events-none w-40 leading-tight z-20">
        Seleccione para ver las opciones de navegación
      </span>
    </div>

    <div class="drop hidden absolute top-full right-0 mt-1 bg-white shadow-lg rounded min-w-30 z-10" id="languageDropdown">
      <a href="/es" class="flag-option flex items-center space-x-2 px-3 py-2 hover:bg-[rgb(219,218,218)] transition" data-lang="es" data-flag={coFlag}>
        <img src={coFlag} alt="Español" width="24" height="16" class="rounded-sm">
        <span>Español</span>
      </a>
      <a href="/en" class="flag-option flex items-center space-x-2 px-3 py-2 hover:bg-[rgb(219,218,218)] transition" data-lang="en" data-flag={gbFlag}>
        <img src={gbFlag} alt="Inglés" width="24" height="16" class="rounded-sm">
        <span>Inglés</span>
      </a>
    </div>
  </div>
</div>

<script>
  const wrapper = document.getElementById('selectedWrapper');
  const dropdown = document.getElementById('languageDropdown');
  const currentFlag = document.getElementById('currentFlag') as HTMLImageElement;
  
  // Abrir/cerrar menú
  wrapper?.addEventListener('click', (e) => {
    e.stopPropagation();
    dropdown?.classList.toggle('hidden');

    //Ocultar tooltip al abrir menú
    const tooltip = wrapper?.querySelector('span');
    if (tooltip) {
      if (dropdown?.classList.contains('hidden')) {
        tooltip.style.opacity = ''; 
      } else {
        tooltip.style.opacity = '0';
      }
    }
  });

  // Cambiar idioma
  document.querySelectorAll('.flag-option').forEach(option => {
    option.addEventListener('click', (e) => {
      e.preventDefault();
      // Actualizar bandera
      const flagSrc = option.getAttribute('data-flag');
      if (currentFlag && flagSrc) {
        currentFlag.src = flagSrc;
        currentFlag.alt = option.querySelector('span')?.textContent || '';
      }
      // Cerrar menú
      dropdown?.classList.add('hidden');
    });
  });
</script>