---
import { EPS_LIST } from '../../data/epsList'
---

<div class="flex flex-col">
  <label for="tipo_identificacion" class="text-[rgb(0,179,160)] mb-2">EPS</label>
  <select 
  id="eps" 
  name="eps"
  required 
  class="w-full border p-2 rounded h-10.5 border-[rgb(168,182,201)] focus:outline-none focus:border-[rgb(0,179,160)]">
    <option value="" disabled selected hidden>EPS</option>
    {
      EPS_LIST.map(eps => (
        <option value={eps.id}>{eps.name}</option>
      ))
    }
  </select>
  <span class="hidden text-red-500 text-sm mt-1">Campo requerido</span>
</div>

<script>
  import { validateSelectRequired } from '../../scripts/formValidations'
    validateSelectRequired("#eps")

</script>