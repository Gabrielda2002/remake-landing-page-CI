---
import { EPS_LIST } from '../../data/epsList'
---

<div class="flex flex-col">
  <label for="tipo_identificacion" class="text-[rgb(0,179,160)] mb-2">EPS</label>
  <select class="w-full border p-2 rounded h-10.5 border-[rgb(168,182,201)] focus:outline-none focus:border-[rgb(0,179,160)] text-gray-400" id="eps" 
  name="eps"
  required >
    <option value="" disabled selected hidden>EPS</option>
    {
      EPS_LIST.map(eps => (
        <option value={eps.id}>{eps.name}</option>
      ))
    }
  </select>
</div>