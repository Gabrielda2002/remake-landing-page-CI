---
import TextContentSection from "./TextContentSection.astro";
const TITLE = "NUESTRO CAMINO";

const SUBTITLE = "Hoy Somos:"

const YEAR = "10 AÑOS";

const PARAGRAPH = "Impulsando la salud con servicios de baja y mediana complejidad, respaldados por excelencia humana y profesional. Nuestras alianzas con EPS de alto prestigio fortalecen nuestra posición en el sector."

const COLOR_PARAGRAPHS = [
  {
    accent: "Pioneros en Norte de Santander:",
    content: "Primeros en obtener la certificación en Buenas Prácticas Clínicas del Invima.",
    i18nKeyAccent: "text.pioneers.accent",
    i18nKeyContent: "text.pioneers.content"
  },
  {
    accent: "Capacidad validada:",
    content: "Autorizados para conducir investigaciones clínicas con medicamentos en seres humanos.",
    i18nKeyAccent: "text.capacity.accent",
    i18nKeyContent: "text.capacity.content"
  },
  {
    accent: "Infraestructura de alto nivel:",
    content: " Espacios y recursos para estudios de Fases II, III y IV.",
    i18nKeyAccent: "text.infrastructure.accent",
    i18nKeyContent: "text.infrastructure.content"
  },
  {
    accent: "Expertos en nuevas evidencias:",
    content: "Desarrollamos estudios observacionales, Real World Evidence (RWE) e Investigación Aplicada.",
    i18nKeyAccent: "text.experts.accent",
    i18nKeyContent: "text.experts.content"
  }
];
---

<TextContentSection
  title={TITLE}
  years={YEAR}
  paragraph= {PARAGRAPH}
  subtitle= {SUBTITLE}
  colorParagraphs={COLOR_PARAGRAPHS}
/>
