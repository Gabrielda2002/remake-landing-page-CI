---
interface Question {
  question: string;
  answer: string;
  text?: string;
  href?: string;
  textHref?: string;
}

interface Props {
  questions: Array<Question>;
  i18nKeyTransation?: string;
}

const { questions, i18nKeyTransation } = Astro.props;
---

<div class="divide-y divide-gray-200">
  {questions.map((item, index) => {
    const id = `faq-${index}`;
    return (
      <div class="accordion-item rounded-lg transition-all duration-200 hover:shadow-md hover:shadow-gray-200/80 hover:-translate-y-0.5 hover:bg-gray-50/60 px-2 m-4">
        <button
          class="accordion-trigger w-full flex justify-between items-center gap-4 py-5 text-left text-gray-900 font-medium hover:text-gray-700"
          aria-expanded="false"
          aria-controls={`answer-${id}`}
          id={`trigger-${id}`}
          data-i18n={i18nKeyTransation && `${i18nKeyTransation}.${index}.question`}
        >
          {item.question}
          <svg
            class="accordion-icon shrink-0 text-gray-400 transition-transform duration-300"
            width="20" height="20" viewBox="0 0 20 20" fill="none"
          >
            <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <div
          class="accordion-content grid grid-rows-[0fr] overflow-hidden transition-all duration-300"
          id={`answer-${id}`}
          role="region"
          aria-labelledby={`trigger-${id}`}
        >
          <div class="overflow-hidden flex flex-col">
            <p
              class="pb-2 text-gray-500 text-sm leading-relaxed"
              data-i18n={i18nKeyTransation && `${i18nKeyTransation}.${index}.answer`}
            >
              {item.answer}
            </p>

            {item.text && (
              <p class="pb-5 text-gray-500 text-sm leading-relaxed">
                <span data-i18n={i18nKeyTransation && `${i18nKeyTransation}.${index}.text`}>
                  {item.text}
                </span>
                {item.href && (
                  <a 
                    href={item.href}
                    class="inline-block mt-2 text-blue-600 hover:text-blue-800 hover:underline font-medium transition-colors duration-200"
                    data-i18n={i18nKeyTransation && `${i18nKeyTransation}.${index}.textHref`}
                  >
                    {item.textHref}
                  </a>
                )}
              </p>
            )}
          </div>
        </div>
      </div>
    );
  })}
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>('.accordion-trigger').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';
      const content = document.getElementById(trigger.getAttribute('aria-controls')!);

      trigger.setAttribute('aria-expanded', String(!isOpen));
      trigger.querySelector('.accordion-icon')?.classList.toggle('rotate-180', !isOpen);
      content?.classList.toggle('grid-rows-[1fr]', !isOpen);
      content?.classList.toggle('grid-rows-[0fr]', isOpen);
    });
  });
</script>