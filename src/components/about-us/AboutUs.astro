---
import type { PropsParagraph } from "../ui/Paragraph.astro"
import banner from '@banner/secondbannerhero.webp';
import diagrama from '@map/diagrama.webp'
import AboutUsInfo from "./AboutUsInfo.astro"

const TITLE = "SOMOS"

const INFORMATION:Array<PropsParagraph> = [
  {
    subtitle:"NORDVITAL IPS SAS",
    paragraph: "Transformamos la investigación clínica en avances reales. Con un equipo experto, tecnología de vanguardia y rigor científico, convertimos el conocimiento en tratamientos que mejoran vidas.",
    i18nKeySubtitle: "aboutUs.nordvital.subtitle",
    i18nKeyParagraph: "aboutUs.nordvital.paragraph"
  },
  {
    subtitle:"NUESTRO COMPROMISO",
    paragraph: "En NORDVITAL IPS SAS ofrecemos servicios de salud ambulatorios de baja y mediana complejidad a nivel nacional. Estamos comprometidos con la salud de nuestros usuarios, con un enfoque en la gestión del riesgo, altos estándares de calidad y seguridad en la atención. Contamos con tecnología de punta y un talento humano idóneo que nos distingue.",
    i18nKeySubtitle: "aboutUs.commitment.subtitle",
    i18nKeyParagraph: "aboutUs.commitment.paragraph"
  },
  {
    subtitle:"NORDVITAL IPS SAS",
    paragraph: "Posicionar a NORDVITAL IPS SAS en el 2029 como una organización líder en innovación, reconocida por su excelencia operativa, humanizada y la calidad de sus servicios.",
    i18nKeySubtitle: "aboutUs.vision.subtitle",
    i18nKeyParagraph: "aboutUs.vision.paragraph"
  }
]

  const TEXT ="Lo hacemos porque creemos en una medicina que evoluciona con propósito. Investigamos para anticiparnos a los desafíos de la salud y ofrecer soluciones reales que mejoren la vida de las personas, <strong>hoy y mañana.</strong>"
---

<AboutUsInfo 
  title={TITLE} 
  information={INFORMATION} 
  banner={banner} 
  text={TEXT}
  diagram={diagrama}
/>