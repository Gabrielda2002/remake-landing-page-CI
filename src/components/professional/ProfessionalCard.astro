---

import Title from '../ui/Title.astro';
import ImageTextCard from '../ui/ImageTextCard.astro';

export interface ProfessionalCard {
  id: string | number
  name?: string,
  image: string
  position: string
}

interface Props {
  title?: string,
  professional: Array<ProfessionalCard>
}

const { title, professional } = Astro.props;
---
<div class="container max-w-6xl mx-auto px-7 font-['Bai_Jamjuree',sans-serif] mt-20 mb-20">
  <Title title={title} />
  <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {professional.map((person: ProfessionalCard, index: number) => (
      <ImageTextCard
        image={person.image}
        alt={`Foto de ${person.name}`}
        title={person.name}
        text={person.position}
        className={professional.length % 3 === 1 && index === professional.length - 1 ? 'lg:col-start-2' : ''}
      >
        <button
          slot="media"
          type="button"
          class="block w-full cursor-pointer appearance-none border-0 bg-transparent p-0 outline-none focus:outline-none focus-visible:outline-none focus-visible:ring-0"
          data-professional-trigger
          data-image-src={person.image}
          data-image-alt={`Foto de ${person.name}`}
        >
          <img
            src={person.image}
            alt={`Foto de ${person.name}`}
            loading="lazy"
            class="block w-full object-cover rounded-xl transition-transform duration-300 hover:scale-[1.01]"
          />
        </button>
      </ImageTextCard>
    ))}
  </div>

  <div
    id="professional-lightbox"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/70 p-4 backdrop-blur-[2px]"
    aria-hidden="true"
  >
    <div class="relative w-full max-w-4xl">
      <button
        type="button"
        class="absolute -top-14 right-0 text-6xl leading-none text-white hover:text-sky-200"
        aria-label="Cerrar imagen ampliada"
        data-lightbox-close
      >
        &times;
      </button>

      <img
        id="professional-lightbox-image"
        src=""
        alt=""
        class="mx-auto max-h-[85vh] w-auto max-w-full rounded-2xl"
      />
    </div>
  </div>
</div>

<script>
  import { initProfessionalLightbox } from '../../scripts/professionalLightbox'
  initProfessionalLightbox();
</script>