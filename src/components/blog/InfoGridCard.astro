---
import GridCard from "./GridCard.astro";
import endimet from '@blog/endimet.webp';

  const AREA = "Curso";
  const TITLE = "Curso Internacional ENDIMET";
  const TEXT = "La La IPS y el Centro de investigación hicieron parte del Curso Internacional ENDIMET de la Asociación Colombiana de Endocrinología, Diabetes y Metabolismo, un reconocido encuentro académico que reunió importantes investigaciones del sector.";
  const DATE = "26 Abril 2026";
---

<GridCard
  image={endimet}
  span={AREA}
  title={TITLE}
  text={TEXT}
  date={DATE}
>
