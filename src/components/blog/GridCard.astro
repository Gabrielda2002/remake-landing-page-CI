---
interface Props {
  area: string,
  title: string,
  text: string
  date: string
}

const {area, title, text, date} = Astro.props;
---

<div class="grid grid-cols-1 gap-6 max-w-[550px]">
  
  <div>
    <div class="md:w-64 h-48 md:h-auto bg-gradient-to-br from-[#3b1f63] to-[#6a4aaa] flex-shrink-0"></div>
    
    <!-- Contenido a la derecha -->
    <div class="flex-1 p-5 flex flex-col">
      <p class="text-[10px] font-semibold tracking-[0.12em] uppercase text-[#999] mb-1.5">
        {area}
      </p>
      <h3 class="font-['Playfair_Display',Georgia,serif] text-lg font-bold leading-snug text-[#1a1a1a] mb-2">
        {title}
      </h3>
      <p class="text-[13px] text-[#777] font-light leading-relaxed mb-3">
        {text}
      </p>
      <div class="flex justify-between items-center text-[11px] text-[#bbb] pt-2 mt-auto">
        <span>{date}</span>
      </div>
    </div>
  </div>
  </div>