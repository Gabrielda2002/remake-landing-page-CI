---
import Title from '../ui/Title.astro';
import Paragraph from '../ui/Paragraph.astro';

export interface ResearchItem {
  id: string | number;
  subtitle: string;
  paragraph: string;
  imageUrl: string ;
  imageAlt: string;
  imagePositionX: 'left' | 'right';
  imagePositionY?: 'top' | 'button';
  serviceList?: string[]
}

export interface Props {
  items: ResearchItem[];
  title?: string;
}

const { items, title } = Astro.props;
---

<div class="container max-w-6xl mx-auto px-4 font-['Bai_Jamjuree',sans-serif] mt-20 mb-20">
  <Title title={title} />
  
  {
    items.map((item, index) => {
      const isImageLeft = item.imagePositionX === 'left' || index % 2 === 0;
      const contentOrderClass = isImageLeft ? 'md:order-1' : 'md:order-2';
      const emptyOrderClass = isImageLeft ? 'md:order-2' : 'md:order-1';

      const imageBlock = (
        <img 
          src={item.imageUrl} 
          alt={item.imageAlt}
          class="w-full h-auto rounded-lg shadow-lg"
          loading="lazy"
        />
      );

      const textBlock = (
        <Paragraph subtitle={item.subtitle} paragraph={item.paragraph}/>
      );

      let contentBlock;

      switch (item.imagePositionY) {
        case 'top':
          contentBlock = (
            <div class="flex flex-col gap-4">
              {imageBlock}
              {textBlock}
            </div>
          );
          break;
        case 'button':
          contentBlock = (
            <div class="flex flex-col gap-4">
              {textBlock}
              {imageBlock}
            </div>
          );
          break;
      }

      return (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start my-12 py-2">
          {
            contentBlock ? (
              <div class={contentOrderClass}>
                {contentBlock}
              </div>

              <div class={emptyOrderClass}>
                {item.serviceList && item.serviceList.length > 0 && (
                  <ul class="flex flex-col gap-2 mt-4 md:mt-0">
                    {item.serviceList.map((service) => (
                      <li class="text-[rgb(86,86,88)] text-[18px] py-2 pl-3.5 border-b border-gray-200 last:border-b-0 flex items-start gap-2">
                        <span class="text-[rgb(0,121,196)]">✓</span>
                        <span>{service}</span>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            ) : (
              <div class={`${isImageLeft ? 'md:order-1' : 'md:order-2'}`}>
                {imageBlock}
              </div>
              <div class={`${isImageLeft ? 'md:order-2' : 'md:order-1'}`}>
                {textBlock}
              </div>
            )
          }
        </div>
      );
    })
  }
</div>