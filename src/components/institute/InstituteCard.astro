---
import Title from '../ui/Title.astro';

export interface InfoInstitute{
  year: string;
  description: string;
  position: 'right' | 'left';
  i18nKeyDescription?:  string
}

interface Props{
  title?: string;
  i18nKeyTitle: string
  information: Array<InfoInstitute>;
}

const { title, i18nKeyTitle, information} = Astro.props as Props;
---

<div class="container max-w-6xl mx-auto px-7 font-['Bai_Jamjuree',sans-serif] mt-20 mb-20">
  <Title title={title} i18nKey={i18nKeyTitle}/>
  <div class="relative mt-10">
    <span
      class="absolute inset-y-0 left-4 z-0 w-0.5 bg-[rgb(175,175,177)] md:left-1/2 md:-translate-x-1/2"
      aria-hidden="true"
    ></span>

    <div class="space-y-4">
      {
        information.map((item) => {
          const isLeft = item.position === 'left';

          return (
            <article
              class="relative pl-12 md:pl-0"
            >
              <span
                class="absolute top-1 left-4 z-10 flex h-5 w-5 -translate-x-1/2 items-center justify-center rounded-full bg-[rgb(49,64,109)] text-[11px] font-bold leading-none text-white ring-4 ring-white md:left-1/2"
                aria-hidden="true"
              >
                ✓
              </span>

              <div
                class={`wrap-break-word md:w-1/2 ${
                  isLeft
                    ? 'md:pr-8 md:mr-auto md:text-right'
                    : 'md:pl-8 md:ml-auto md:text-left'
                }`}
              >
                <p class="text-[rgb(0,179,160)] leading-none font-bold">{item.year}</p>
                <p data-i18n={item.i18nKeyDescription}
                  class="text-[rgb(86,86,88)] leading-relaxed">
                    {item.description}
                </p>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>


</div>